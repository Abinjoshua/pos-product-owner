<?xml version="1.0" encoding="UTF-8" ?>
<template xml:space="preserve">
    <t t-name="Orderline" t-inherit="point_of_sale.orderline"
       t-inherit-mode="extension">
        <xpath expr="//li[hasclass('orderline')]/div[hasclass('d-flex')]"
               position="after">
            <br/>
            <t t-if="line.product_owner_id[1]">
                    <span><b>Product Owner:</b>
                        <t t-esc="line.product_owner_id[1]"/>
                    </span>
            </t>
        </xpath>
    </t>
</template>